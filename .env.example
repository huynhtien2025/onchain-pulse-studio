# App
NODE_ENV=production
ENABLE_LIVE_TRADING=false

# SoSoValue API
SOSOVALUE_API_KEY=
SOSOVALUE_BASE_URL=https://openapi.sosovalue.com/openapi/v1
SOSOVALUE_AUTH_HEADER=x-api-key

# Optional: override exact SoSoValue paths if your dashboard docs use different paths
SOSOVALUE_MARKET_PATH=
SOSOVALUE_NEWS_PATH=
SOSOVALUE_ETF_PATH=
SOSOVALUE_INDEX_PATH=

# SoDEX API
SODEX_SPOT_BASE_URL=https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_PERPS_BASE_URL=https://mainnet-gw.sodex.dev/api/v1/perps
SODEX_USER_ADDRESS=
SODEX_ACCOUNT_ID=
SODEX_API_KEY_NAME=
SODEX_API_PUBLIC_KEY=
SODEX_API_PRIVATE_KEY=

# Live market backup, kept internal to backend/UI wording
MARKET_BACKUP_BASE_URL=https://api.binance.com/api/v3
